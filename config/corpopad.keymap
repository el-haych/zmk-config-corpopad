    keymap {
        compatible = "zmk,keymap";

        default_layer {
            display-name = "Base";
            bindings = <
            &PMLE       &TYFYE            &CONTACT
            &kp K_PREV  &kp K_PLAY_PAUSE  &kp K_NEXT
            &mo 1       &kp K_MUTE        &kp LS(KP_ENTER)
            >;
        };

        bt_layer {
            display-name = "BT";
            bindings = <
            &bt BT_SEL 0  &bt BT_SEL 1    &bt BT_SEL 3
            &none         &studio_unlock  &none
            &none         &none           &bootloader
            >;
        };
    };
